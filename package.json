{
  "name": "woo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "catalog:index": "node scripts/generate-bundled-catalog-index.mjs",
    "guard:object-names": "node scripts/check-no-demo-object-names.mjs",
    "guard:catalog-migrations": "node scripts/guard-catalog-migrations.mjs",
    "predev": "npm run catalog:index",
    "dev": "tsx src/server/dev-server.ts",
    "dump:json": "tsx src/server/dump-json.ts",
    "mcp:stdio": "tsx src/mcp/stdio.ts",
    "cf:migrations": "node scripts/sync-wrangler-do-migrations.mjs --write",
    "cf:migrations:check": "node scripts/sync-wrangler-do-migrations.mjs --check",
    "plugs:bootstrap": "node scripts/bootstrap-demo-plugs.mjs",
    "storage:profile": "tsx scripts/profile-storage-writes.ts",
    "v2:profile": "tsx scripts/profile-shadow-turn-network.ts",
    "pretest": "npm run catalog:index && npm run guard:object-names && npm run guard:catalog-migrations",
    "test": "vitest run --reporter=dot",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "pretypecheck": "npm run catalog:index && npm run guard:object-names && npm run guard:catalog-migrations",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "prebuild": "npm run catalog:index",
    "build": "vite build",
    "deploy": "scripts/deploy.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "vite": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260430.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "ip-address": "^10.1.1",
    "fast-uri": "^3.1.2"
  }
}
